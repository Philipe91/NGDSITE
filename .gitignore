# =============================================================================
# NGD Site — .gitignore
# =============================================================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# Ambiente virtual
.venv/
venv/
ENV/
env/

# Django
*.log
logs/
local_settings.py
db.sqlite3
staticfiles/
media/

# Variáveis de ambiente — NUNCA commitar!
.env
.env.local
.env.production
.env.*.local

# Backups e dumps de banco — podem conter dados de cliente
*.sql
*.sql.gz
*.dump
backups/
backup_*.sql

# Binários e ferramentas locais
cloudflared.exe
*.exe
!seed.py
list_users_temp.py
*_temp.py

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Sistema operacional
.DS_Store
Thumbs.db
