# =============================================================================
# VARIÁVEIS DE AMBIENTE — NGD SITE (Web-to-Print)
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o .env no controle de versão.
# =============================================================================

# --------------------------------------------------------------------------
# DJANGO CORE
# --------------------------------------------------------------------------
# Gere uma chave forte com:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=GERAR-CHAVE-FORTE-EM-PRODUCAO

# Em desenvolvimento: True. Em produção: False (obriga HTTPS, HSTS, cookies seguros).
DEBUG=True

# Hosts liberados (separe por vírgula). Em produção use o domínio real.
ALLOWED_HOSTS=localhost,127.0.0.1

# Origens CSRF extras (https://meusite.com.br) — separadas por vírgula. Opcional.
CSRF_TRUSTED_ORIGINS_EXTRA=

# --------------------------------------------------------------------------
# BANCO DE DADOS — PostgreSQL
# --------------------------------------------------------------------------
DB_NAME=ngdsite
DB_USER=postgres
DB_PASSWORD=TROCAR-EM-PRODUCAO
DB_HOST=localhost
DB_PORT=5432
# Tempo (s) que conexões Postgres são reutilizadas. 0 = desabilita pool persistente.
DB_CONN_MAX_AGE=60

# --------------------------------------------------------------------------
# CACHE — opcional. Defina REDIS_URL para usar Redis em produção.
# Exemplo: redis://localhost:6379/1
# --------------------------------------------------------------------------
REDIS_URL=

# --------------------------------------------------------------------------
# E-MAIL — em prod use SendGrid/Postmark/Mailgun ou SMTP real.
# --------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=NGD <ngd@nucleografico.com.br>

# --------------------------------------------------------------------------
# MERCADO PAGO
# --------------------------------------------------------------------------
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_SANDBOX=True
# OBRIGATÓRIO em produção — gere no painel MP > Webhooks > Sua chave secreta.
# Em DEBUG=True, se vazio, o webhook é aceito mas é registrado um aviso.
MP_WEBHOOK_SECRET=

# --------------------------------------------------------------------------
# UPLOADS
# --------------------------------------------------------------------------
# Tamanho máximo de upload de arte do cliente (bytes). Default 50 MB.
ART_UPLOAD_MAX_BYTES=52428800

# --------------------------------------------------------------------------
# TELEGRAM (notificações de pedido)
# --------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --------------------------------------------------------------------------
# FRETE / LOJA
# --------------------------------------------------------------------------
SHIPPING_FIXED_COST=25.00
STORE_ADDRESS=Av. Principal, 1000 - Centro

# --------------------------------------------------------------------------
# URL BASE DO SITE — usada nos callbacks do Mercado Pago
# Em prod: https://seudominio.com.br
# --------------------------------------------------------------------------
SITE_URL=http://localhost:8000
