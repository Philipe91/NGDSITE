# =============================================================================
# VARIÁVEIS DE AMBIENTE — NGD SITE (Web-to-Print)
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no controle de versão.
# =============================================================================

# --- Django ---
SECRET_KEY=sua-chave-secreta-aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL ---
DB_NAME=ngdsite
DB_USER=postgres
DB_PASSWORD=sua-senha-aqui
DB_HOST=localhost
DB_PORT=5432
